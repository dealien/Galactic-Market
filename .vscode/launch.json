    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug (CodeLLDB)",
            "type": "lldb",
            "request": "launch",
            "program": "${workspaceFolder}/target/debug/galactic-market.exe",
            "args": [],
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "Prepare for Debugging"
        },
        {
            "name": "Debug tests (CodeLLDB)",
            "type": "lldb",
            "request": "launch",
            "cargo": {
                "args": [
                    "test",
                    "--no-run",
                    "--bin=galactic-market"
                ]
            },
            "args": [],
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "Prepare for Debugging"
        },
        {
            "name": "Run All Checks (Lint, Format, Test)",
            "type": "node",
            "request": "launch",
            "preLaunchTask": "Check All (lint, format, test)",
            "runtimeExecutable": "node"
        }
    ]
}