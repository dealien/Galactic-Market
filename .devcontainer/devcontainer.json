{
  "name": "Galactic Market Simulator",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:4.0.0": {}
  },
  "forwardPorts": [
    5432
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "rust-lang.rust-analyzer",
        "tamasfe.even-better-toml",
        "mtxr.sqltools",
        "mtxr.sqltools-driver-pg",
        "vadimcn.vscode-lldb",
        "fill-labs.dependi",
        "fogio.coverlens"
      ],
      "settings": {
        "rust-analyzer.check.command": "clippy",
        "rust-analyzer.check.extraArgs": [
          "--",
          "-D",
          "warnings"
        ],
        "coverlens.testRunner.mode": "custom",
        "coverlens.testRunner.customCommand": "cargo llvm-cov --all-features --workspace --lcov --output-path lcov.info"
      }
    }
  },
  "containerEnv": {
    "DATABASE_URL": "postgres://postgres:password@localhost:5432/galactic_market"
  },
  "postCreateCommand": "docker compose up -d --wait && cargo build",
  "remoteUser": "vscode"
}